{
  "manifest_version": 3,
  "name": "Smart Page Translator",
  "version": "2.0",
  "description": "Translate entire webpage and replace original text",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart Page Translator"
  }
}